generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?
  riotAccountId String?   // For later Riot verification
  accounts      Account[]
  matchupNotes  MatchupNote[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  TOP
  JGL
  MID
  ADC
  SUPP
}

model MatchupNote {
  id             String   @id @default(cuid())
  userId         String
  role           Role
  myChampion     String
  enemyChampion  String
  mySupport      String?  // Optional for bot lane
  enemySupport   String?  // Optional for bot lane
  prio           String?  // e.g., "My", "Enemy", "50/50"
  wins           Int      @default(0)
  losses         Int      @default(0)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("matchup_notes")
}
