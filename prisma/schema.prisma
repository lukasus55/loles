generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash   String?
  riotAccountId  String?   // For later Riot verification
  primaryRole    Role?
  iconPreference String    @default("NONE")
  accounts       Account[]
  matchupNotes  MatchupNote[]
  riotAccount   RiotAccount?
  matches       Match[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  TOP
  JGL
  MID
  ADC
  SUPP
}

model MatchupNote {
  id             String   @id @default(cuid())
  userId         String
  role           Role
  myChampion     String
  enemyChampion  String
  mySupport      String?  // Optional for bot lane
  enemySupport   String?  // Optional for bot lane
  prio           String?  // e.g., "My", "Enemy", "50/50"
  wins           Int      @default(0)
  losses         Int      @default(0)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("matchup_notes")
}

model RiotAccount {
  id            String   @id @default(cuid())
  userId        String   @unique
  puuid         String   
  gameName      String
  tagLine       String
  region        String
  profileIconId Int
  summonerId    String?  
  tier          String?
  rank          String?
  leaguePoints  Int?
  lastSyncedAt  DateTime?
  isVerified    Boolean  @default(false)
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("riot_accounts")
}

model Match {
  id            String   @id @default(cuid())
  matchId       String   // Riot's internal match ID (e.g. EUW1_12345678)
  userId        String
  puuid         String
  
  // Game Data
  season        Int      @default(16)
  gameCreation  DateTime // When the game started
  gameDuration  Int      // In seconds
  queueId       Int      // 420 for Solo, 440 for Flex
  
  // Player Performance
  championId    Int
  championName  String
  role          String   // TOP, JUNGLE, MIDDLE, BOTTOM, UTILITY
  win           Boolean
  kills         Int
  deaths        Int
  assists       Int
  cs            Int
  goldEarned    Int?
  totalDamageDealtToChampions Int?
  visionScore   Int?
  
  // Lane Opponent Performance (Simplified for now, can be populated if needed)
  enemyChampionName String?
  partnerChampionName String?
  enemyPartnerChampionName String?
  
  // Early Game Stats (at 15 mins)
  csAt15        Int?
  goldAt15      Int?
  laneKills     Int?
  enemyCsAt15   Int?
  enemyGoldAt15 Int?
  enemyLaneKills Int?

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([matchId, userId])
  @@index([userId])
  @@index([userId, season])
  @@index([userId, championName])
  @@map("matches")
}
